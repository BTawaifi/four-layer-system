## Quality Scoring Algorithm

### Dimension-Based Scoring
```python
def calculate_quality_score(self, validation_results, layer_type):
    """Calculate comprehensive quality score"""

    # Initialize dimension scores
    dimensions = {
        'completeness': {'score': 0, 'max': 0},
        'depth': {'score': 0, 'max': 0},
        'accuracy': {'score': 0, 'max': 0},
        'usability': {'score': 0, 'max': 0},
        'integration': {'score': 0, 'max': 0}
    }

    # Map validation results to dimensions
    dimension_mapping = self.get_dimension_mapping(layer_type)

    for check_name, check_result in validation_results.items():
        if check_name in dimension_mapping:
            dimension = dimension_mapping[check_name]
            dimensions[dimension]['max'] += 1
            if check_result['passed']:
                dimensions[dimension]['score'] += 1

    # Calculate dimension percentages
    dimension_scores = {}
    for dimension, scores in dimensions.items():
        if scores['max'] > 0:
            dimension_scores[dimension] = (scores['score'] / scores['max']) * 10
        else:
            dimension_scores[dimension] = 0

    # Apply dimension weights
    weights = {
        'completeness': 0.25,
        'depth': 0.25,
        'accuracy': 0.20,
        'usability': 0.15,
        'integration': 0.15
    }

    total_score = sum(dimension_scores[dimension] * weights[dimension]
                     for dimension in dimension_scores.keys())

    return {
        'total_score': round(total_score, 1),
        'dimension_scores': {k: round(v, 1) for k, v in dimension_scores.items()},
        'weights': weights,
        'grade': self.get_grade(total_score)
    }
```

