```python
def validate_specialist_competencies(self, content):
    """Validate specialist competencies section"""
    # Check for required competency categories
    required_categories = ['Core Competencies', 'Key Guidelines']

    content_sections = self.extract_sections(content)
    missing_sections = []

    for category in required_categories:
        if category.lower() not in [s.lower() for s in content_sections]:
            missing_sections.append(category)

    # Check competency depth
    competencies_section = self.extract_section(content, 'Core Competencies')
    competency_count = len(re.findall(r'^- ', competencies_section))

    return {
        'passed': len(missing_sections) == 0 and competency_count >= 8,
        'details': f"Missing sections: {missing_sections}, Found {competency_count} competencies (need 8+)" if missing_sections or competency_count < 8 else "Competencies section complete and comprehensive",
        'missing_sections': missing_sections,
        'competency_count': competency_count
    }
```

#### Workflow Structure Validation
```python
def validate_workflow_phases(self, content):
    """Validate workflow phase structure"""
    # Extract phase information
    phases = re.findall(r'### Phase \d+', content)
    phase_count = len(phases)

    # Check for STOP AND WAIT patterns
    stop_wait_count = len(re.findall(r'STOP AND WAIT', content))

    # Validate phase completeness
    complete_phases = 0
    for phase in phases:
        phase_content = self.extract_phase_content(content, phase)
        if self.is_phase_complete(phase_content):
            complete_phases += 1

    return {
        'passed': phase_count >= 3 and stop_wait_count >= 2 and complete_phases == phase_count,
        'details': f"Found {phase_count} phases, {stop_wait_count} STOP AND WAIT statements, {complete_phases}/{phase_count} complete phases",
        'phase_count': phase_count,
        'stop_wait_count': stop_wait_count,
        'complete_phases': complete_phases
    }
```

