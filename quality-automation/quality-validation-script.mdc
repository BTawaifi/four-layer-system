#### 3. Quality Scorer
```python
class QualityScorer:
    def __init__(self):
        self.weights = {
            'completeness': 0.25,
            'depth': 0.25,
            'accuracy': 0.20,
            'usability': 0.15,
            'integration': 0.15
        }

        self.layer_weights = {
            'specialists': {
                'yaml_completeness': 'completeness',
                'persona_completeness': 'completeness',
                'competencies_completeness': 'depth',
                'guidelines_quality': 'usability',
                'cross_references_accuracy': 'integration'
            },
            'workflows': {
                'action_clarity': 'usability',
                'phase_completeness': 'completeness',
                'task_specificity': 'depth',
                'context_usage': 'integration'
            }
            # Additional layer mappings...
        }

    def calculate_score(self, results, layer_type):
        """Calculate weighted quality score"""
        dimension_scores = {}

        for dimension in self.weights.keys():
            dimension_score = 0
            dimension_checks = 0

            for check_name, check_result in results.items():
                if check_name in self.layer_weights.get(layer_type, {}):
                    if self.layer_weights[layer_type][check_name] == dimension:
                        dimension_score += 1 if check_result['passed'] else 0
                        dimension_checks += 1

            dimension_scores[dimension] = dimension_score / dimension_checks if dimension_checks > 0 else 0

        total_score = sum(dimension_scores[dimension] * self.weights[dimension]
                         for dimension in dimension_scores.keys())

        return {
            'total_score': round(total_score * 10, 1),  # Convert to 0-10 scale
            'dimension_scores': {k: round(v * 10, 1) for k, v in dimension_scores.items()},
            'max_score': 10.0,
            'grade': self.get_grade(total_score * 10)
        }

    def get_grade(self, score):
        """Convert score to letter grade"""
        if score >= 9.0: return 'A'
        elif score >= 8.0: return 'B'
        elif score >= 7.0: return 'C'
        elif score >= 6.0: return 'D'
        else: return 'F'
```

#### 4. Improvement Generator
```python
class ImprovementGenerator:
    def generate_improvements(self, results, layer_type):
        """Generate specific improvement suggestions"""
        improvements = {
            'critical': [],    # Must fix immediately
            'high': [],        # Should fix soon
            'medium': [],      # Consider fixing
            'low': []          # Nice to have
        }

        for check_name, check_result in results.items():
            if not check_result['passed']:
                suggestion = self.get_suggestion(check_name, check_result, layer_type)
                priority = self.determine_priority(check_name, check_result, layer_type)
                improvements[priority].append(suggestion)

        return improvements

    def get_suggestion(self, check_name, check_result, layer_type):
        """Generate specific improvement suggestion"""
        suggestions = {
            'yaml_completeness': "Add missing required YAML fields (alwaysApply, description)",
            'cross_references_accuracy': "Fix broken cross-references to valid rules",
            'phase_completeness': "Ensure all workflow phases have clear objectives and completion criteria",
            'task_specificity': "Replace high-level tasks with specific, actionable steps",
            # Additional suggestions...
        }

        return suggestions.get(check_name, f"Review and improve {check_name.replace('_', ' ')}")

    def determine_priority(self, check_name, check_result, layer_type):
        """Determine improvement priority"""
        critical_checks = ['yaml_completeness', 'cross_references_accuracy']
        high_checks = ['phase_completeness', 'task_specificity']

        if check_name in critical_checks:
            return 'critical'
        elif check_name in high_checks:
            return 'high'
        else:
            return 'medium'
