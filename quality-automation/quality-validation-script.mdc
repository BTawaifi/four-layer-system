## Validation Rules and Checks

### YAML Frontmatter Validation

#### Required Fields Check
```python
def validate_yaml_frontmatter(self, content):
    """Validate required YAML frontmatter fields"""
    required_fields = ['alwaysApply', 'description']

    try:
        frontmatter = self.extract_frontmatter(content)

        missing_fields = []
        for field in required_fields:
            if field not in frontmatter:
                missing_fields.append(field)

        return {
            'passed': len(missing_fields) == 0,
            'details': f"Missing required fields: {missing_fields}" if missing_fields else "All required fields present",
            'missing_fields': missing_fields
        }
    except Exception as e:
        return {
            'passed': False,
            'details': f"YAML parsing error: {str(e)}",
            'error': str(e)
        }
```

#### Field Type Validation
```python
def validate_yaml_field_types(self, content):
    """Validate YAML field types and formats"""
    expected_types = {
        'alwaysApply': bool,
        'description': str
    }

    try:
        frontmatter = self.extract_frontmatter(content)

        type_errors = []
        for field, expected_type in expected_types.items():
            if field in frontmatter:
                if not isinstance(frontmatter[field], expected_type):
                    type_errors.append(f"{field}: expected {expected_type.__name__}, got {type(frontmatter[field]).__name__}")

        return {
            'passed': len(type_errors) == 0,
            'details': f"Type errors: {type_errors}" if type_errors else "All field types correct",
            'type_errors': type_errors
        }
    except Exception as e:
        return {
            'passed': False,
            'details': f"Validation error: {str(e)}",
            'error': str(e)
        }
```

### Content Structure Validation

#### Markdown Syntax Check
```python
def validate_markdown_syntax(self, content):
    """Validate markdown syntax and structure"""
    issues = []

    # Check for proper header hierarchy
    headers = re.findall(r'^(#{1,6})\s+(.+)$', content, re.MULTILINE)
    for level, text in headers:
        level_num = len(level)
        if level_num > 6:
            issues.append(f"Header level {level_num} exceeds maximum of 6")

    # Check for proper link syntax
    links = re.findall(r'\[([^\]]+)\]\(([^)]+)\)', content)
    for text, url in links:
        if not url.startswith(('http', 'https', '#', '@')):
            issues.append(f"Invalid link URL format: {url}")

    return {
        'passed': len(issues) == 0,
        'details': f"Found {len(issues)} markdown issues" if issues else "Markdown syntax valid",
        'issues': issues
    }
```

#### Cross-Reference Validation
```python
def validate_cross_references(self, content):
    """Validate cross-references to other rules"""
    references = re.findall(r'@([a-z-]+)', content)
    invalid_refs = []

    for ref in references:
        if not self.is_valid_rule_reference(ref):
            invalid_refs.append(ref)

    return {
        'passed': len(invalid_refs) == 0,
        'details': f"Found {len(invalid_refs)} invalid cross-references" if invalid_refs else "All cross-references valid",
        'invalid_references': invalid_refs
    }
