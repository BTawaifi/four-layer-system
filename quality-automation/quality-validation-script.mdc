## Script Architecture

### Core Components

#### 1. Quality Validator Class
```python
class QualityValidator:
    def __init__(self, config_path="quality_config.json"):
        self.config = self.load_config(config_path)
        self.validators = self.initialize_validators()
        self.scorer = QualityScorer()
        self.reporter = QualityReporter()

    def validate_file(self, file_path):
        """Validate single file and return quality assessment"""
        content = self.load_content(file_path)
        layer_type = self.identify_layer(file_path)

        results = {}
        for validator in self.validators[layer_type]:
            results.update(validator.validate(content))

        score = self.scorer.calculate_score(results, layer_type)
        suggestions = self.generate_improvements(results, layer_type)

        return {
            'file': file_path,
            'layer': layer_type,
            'results': results,
            'score': score,
            'suggestions': suggestions,
            'timestamp': datetime.now().isoformat()
        }

    def validate_directory(self, directory_path, recursive=True):
        """Validate all files in directory"""
        results = []
        for file_path in self.find_mdc_files(directory_path, recursive):
            result = self.validate_file(file_path)
            results.append(result)
            self.log_validation(result)

        return self.aggregate_results(results)
```

