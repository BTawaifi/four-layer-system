## Reporting and Output

### Validation Report Generation
```python
def generate_validation_report(self, results, output_format='json'):
    """Generate comprehensive validation report"""

    report = {
        'summary': {
            'total_files': len(results),
            'timestamp': datetime.now().isoformat(),
            'validation_version': '1.0'
        },
        'quality_distribution': self.calculate_quality_distribution(results),
        'top_issues': self.identify_top_issues(results),
        'improvement_suggestions': self.aggregate_improvements(results),
        'detailed_results': results
    }

    if output_format == 'json':
        return json.dumps(report, indent=2)
    elif output_format == 'markdown':
        return self.generate_markdown_report(report)
    else:
        return report
```

### Quality Distribution Analysis
```python
def calculate_quality_distribution(self, results):
    """Analyze quality score distribution"""
    scores = [result['score']['total_score'] for result in results]

    distribution = {
        'excellent': len([s for s in scores if s >= 9.0]),  # 9.0-10.0
        'good': len([s for s in scores if 8.0 <= s < 9.0]),  # 8.0-8.9
        'satisfactory': len([s for s in scores if 7.0 <= s < 8.0]),  # 7.0-7.9
        'needs_improvement': len([s for s in scores if 6.0 <= s < 7.0]),  # 6.0-6.9
        'insufficient': len([s for s in scores if s < 6.0])  # 0.0-5.9
    }

    return {
        'distribution': distribution,
        'average_score': round(sum(scores) / len(scores), 1),
        'median_score': sorted(scores)[len(scores) // 2],
        'score_range': {
            'min': min(scores),
            'max': max(scores)
        }
    }
```

